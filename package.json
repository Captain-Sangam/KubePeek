{
  "name": "kubepeek",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "dev": "concurrently -k \"npm:dev:next\" \"npm:dev:electron\"",
    "dev:web": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "dist": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@kubernetes/client-node": "^0.20.0",
    "@mui/icons-material": "^5.15.9",
    "@mui/material": "^5.15.9",
    "aws-sdk": "^2.1692.0",
    "js-yaml": "^4.1.0",
    "next": "14.1.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  }
}
