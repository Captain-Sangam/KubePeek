{
  "name": "kubepeek",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "dev": "concurrently -k \"npm:dev:next\" \"npm:dev:electron\"",
    "dev:web": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "dist": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.8",
    "@astryxdesign/theme-neutral": "0.1.8",
    "@kubernetes/client-node": "^0.20.0",
    "@stylexjs/stylex": "^0.19.0",
    "aws-sdk": "^2.1692.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.26.0",
    "next": "^15.5.21",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8",
    "eslint-config-next": "^15.5.21",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  }
}
